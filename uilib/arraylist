local ArrayList = {
    Entries = {},
    Config = {
        Visible = true,
        Side = "Right", 
        Font = Enum.Font.BuilderSansMedium,
        TextSize = 16,
        Padding = 0, 
        BackgroundTransparency = 0.6,
        BackgroundColor = Color3.fromRGB(15, 15, 15),
        LineEnabled = true,
        LineWidth = 3,
        LineOffset = 5,
        DefaultTextColor = Color3.fromRGB(255, 255, 255),
        RainbowTextColors = true
    }
}

local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
ScreenGui.Name = "rat.fun_ArrayList"

local Container = Instance.new("Frame", ScreenGui)
Container.BackgroundTransparency = 1

local BorderLine = Instance.new("Frame", ScreenGui)
BorderLine.BorderSizePixel = 0
BorderLine.BackgroundTransparency = 1

local UIGradient = Instance.new("UIGradient", BorderLine)
UIGradient.Rotation = 90

local UIListLayout = Instance.new("UIListLayout", Container)
UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder

local function updateLayout()
    local isRight = (ArrayList.Config.Side == "Right")
    
    Container.Size = UDim2.new(0, 220, 1, 0)
    Container.Position = isRight and UDim2.new(1, -(220 + ArrayList.Config.LineOffset + ArrayList.Config.LineWidth), 0, 5) or UDim2.new(0, ArrayList.Config.LineOffset + ArrayList.Config.LineWidth, 0, 5)
    
    UIListLayout.HorizontalAlignment = isRight and Enum.HorizontalAlignment.Right or Enum.HorizontalAlignment.Left
    UIListLayout.Padding = UDim.new(0, ArrayList.Config.Padding)
    
    local sorted = {}
    for _, label in pairs(ArrayList.Entries) do
        table.insert(sorted, label)
    end
    table.sort(sorted, function(a, b)
        return a.LayoutOrder < b.LayoutOrder
    end)
    
    if #sorted == 0 then 
        BorderLine.BackgroundTransparency = 1
        return 
    end
    
    local keypoints = {}
    local step = 1 / math.max(#sorted - 1, 1)
    
    for i, label in ipairs(sorted) do
        local timePos = math.clamp((i - 1) * step, 0, 1)
        
        if ArrayList.Config.RainbowTextColors then
            local hue = timePos * 0.7
            label.TextColor3 = Color3.fromHSV(hue, 0.8, 1)
        else
            label.TextColor3 = ArrayList.Config.DefaultTextColor
        end
        
        table.insert(keypoints, ColorSequenceKeypoint.new(timePos, label.TextColor3))
        
        label.Font = ArrayList.Config.Font
        label.TextSize = ArrayList.Config.TextSize
        label.BackgroundColor3 = ArrayList.Config.BackgroundColor
        label.BackgroundTransparency = ArrayList.Config.BackgroundTransparency
    end
    
    if #keypoints == 1 then
        table.insert(keypoints, ColorSequenceKeypoint.new(1, keypoints[1].Value))
    end
    
    if ArrayList.Config.LineEnabled then
        BorderLine.BackgroundTransparency = 0
        UIGradient.Color = ColorSequence.new(keypoints)
        
        local totalHeight = 0
        for _, label in ipairs(sorted) do
            totalHeight = totalHeight + label.AbsoluteSize.Y + ArrayList.Config.Padding
        end
        
        BorderLine.Size = UDim2.new(0, ArrayList.Config.LineWidth, 0, totalHeight)
        BorderLine.Position = isRight and UDim2.new(1, -ArrayList.Config.LineOffset, 0, 5) or UDim2.new(0, ArrayList.Config.LineOffset - ArrayList.Config.LineWidth, 0, 5)
    else
        BorderLine.BackgroundTransparency = 1
    end
end

function ArrayList.add(name)
    if ArrayList.Entries[name] then return end
    
    local Entry = Instance.new("TextLabel")
    Entry.Name = name
    Entry.Text = " " .. name .. " "
    Entry.BorderSizePixel = 0
    Entry.AutomaticSize = Enum.AutomaticSize.XY
    Entry.Parent = Container
    
    ArrayList.Entries[name] = Entry
    ArrayList.Sort()
    
    task.spawn(function()
        task.wait()
        updateLayout()
    end)
    
    return Entry
end

function ArrayList.Remove(name)
    if ArrayList.Entries[name] then
        ArrayList.Entries[name]:Destroy()
        ArrayList.Entries[name] = nil
        ArrayList.Sort()
        updateLayout()
    end
end

function ArrayList.Sort()
    local sorted = {}
    for name, label in pairs(ArrayList.Entries) do
        table.insert(sorted, {name = name, label = label})
    end
    
    table.sort(sorted, function(a, b)
        return a.label.TextBounds.X > b.label.TextBounds.X
    end)
    
    for i, data in ipairs(sorted) do
        data.label.LayoutOrder = i
    end
end

return ArrayList
