local CoreGui = (gethui and gethui()) or game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local MarketplaceService = game:GetService("MarketplaceService")

local GameName = MarketplaceService:GetProductInfo(game.PlaceId).Name

local Games = {
    [1234567890] = "https://raw.githubusercontent.com/you/script1.lua",
    [9876543210] = "https://raw.githubusercontent.com/you/script2.lua",
    [1112223333] = "loadstring(game:HttpGet('https://raw.githubusercontent.com/you/script3.lua'))()",
}

local BG = Color3.fromRGB(25, 25, 25)
local Stroke = Color3.fromRGB(45, 45, 45)
local TextColor = Color3.fromRGB(200, 200, 200)
local Accent = Color3.fromRGB(138, 28, 138)

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "ratfun_loader"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.IgnoreGuiInset = true
ScreenGui.Parent = CoreGui

local Holder = Instance.new("Frame")
Holder.Name = "Holder"
Holder.Size = UDim2.fromOffset(0, 0)
Holder.Position = UDim2.fromScale(0.5, 0.5)
Holder.AnchorPoint = Vector2.new(0.5, 0.5)
Holder.BackgroundColor3 = BG
Holder.BorderSizePixel = 0
Holder.ClipsDescendants = false
Holder.Visible = false
Holder.Parent = ScreenGui

Instance.new("UICorner", Holder).CornerRadius = UDim.new(0, 8)

local StrokeInst = Instance.new("UIStroke")
StrokeInst.Color = Stroke
StrokeInst.Thickness = 1.5
StrokeInst.Transparency = 1
StrokeInst.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
StrokeInst.Parent = Holder

local Title = Instance.new("TextLabel")
Title.Name = "Title"
Title.Size = UDim2.new(1, -20, 0, 20)
Title.Position = UDim2.fromOffset(10, 12)
Title.BackgroundTransparency = 1
Title.TextColor3 = TextColor
Title.FontFace = Font.new("rbxassetid://12187365364")
Title.TextSize = 16
Title.TextXAlignment = Enum.TextXAlignment.Left
Title.TextTransparency = 1
Title.Text = "rat.fun"
Title.Parent = Holder

local StatusLabel = Instance.new("TextLabel")
StatusLabel.Name = "Status"
StatusLabel.Size = UDim2.new(1, -20, 0, 14)
StatusLabel.Position = UDim2.new(0, 10, 0, 34)
StatusLabel.BackgroundTransparency = 1
StatusLabel.TextColor3 = Color3.fromRGB(120, 120, 120)
StatusLabel.FontFace = Font.new("rbxassetid://12187365364")
StatusLabel.TextSize = 12
StatusLabel.TextXAlignment = Enum.TextXAlignment.Left
StatusLabel.TextTransparency = 1
StatusLabel.Text = "loading..."
StatusLabel.Parent = Holder

local ProgressBarBG = Instance.new("Frame")
ProgressBarBG.Name = "ProgressBG"
ProgressBarBG.Size = UDim2.new(1, -12, 0, 2)
ProgressBarBG.Position = UDim2.new(0, 6, 1, -5)
ProgressBarBG.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
ProgressBarBG.BorderSizePixel = 0
ProgressBarBG.ZIndex = 6
ProgressBarBG.Parent = Holder
Instance.new("UICorner", ProgressBarBG).CornerRadius = UDim.new(1, 0)

local ProgressBar = Instance.new("Frame")
ProgressBar.Name = "Fill"
ProgressBar.Size = UDim2.fromScale(0, 1)
ProgressBar.BackgroundColor3 = Accent
ProgressBar.BorderSizePixel = 0
ProgressBar.ZIndex = 7
ProgressBar.Parent = ProgressBarBG
Instance.new("UICorner", ProgressBar).CornerRadius = UDim.new(1, 0)

local FadeIn = TweenInfo.new(0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
local EaseOut = TweenInfo.new(0.6, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

Holder.Visible = true
TweenService:Create(Holder, EaseOut, {Size = UDim2.fromOffset(260, 60)}):Play()
TweenService:Create(StrokeInst, FadeIn, {Transparency = 0}):Play()
task.wait(0.3)

TweenService:Create(Title, FadeIn, {TextTransparency = 0}):Play()
task.wait(0.1)
TweenService:Create(StatusLabel, FadeIn, {TextTransparency = 0}):Play()
task.wait(0.15)

local Duration = 2.5
local Elapsed = 0
local LastTick = tick()
while Elapsed < Duration do
    task.wait()
    Elapsed = Elapsed + (tick() - LastTick)
    LastTick = tick()
    local Pct = math.clamp(Elapsed / Duration, 0, 1)
    TweenService:Create(ProgressBar, TweenInfo.new(0.1), {Size = UDim2.fromScale(Pct, 1)}):Play()
end

StatusLabel.Text = "detected  " .. GameName

task.wait(0.5)

local FadeOut = TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.In)

TweenService:Create(Title, FadeOut, {TextTransparency = 1}):Play()
TweenService:Create(StatusLabel, FadeOut, {TextTransparency = 1}):Play()
TweenService:Create(StrokeInst, FadeOut, {Transparency = 1}):Play()
TweenService:Create(ProgressBar, FadeOut, {BackgroundTransparency = 1}):Play()
TweenService:Create(ProgressBarBG, FadeOut, {BackgroundTransparency = 1}):Play()

task.wait(0.2)
TweenService:Create(Holder, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Size = UDim2.fromOffset(0, 0)}):Play()
task.wait(0.45)

ScreenGui:Destroy()

local Script = Games[game.PlaceId]
if Script then
    if Script:match("^https?://") then
        loadstring(game:HttpGet(Script))()
    else
        loadstring(Script)()
    end
end
